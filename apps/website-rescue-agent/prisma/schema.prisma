// Website Rescue Agent – Prisma Schema (SQLite-kompatibel)
// Letzte Änderung: 2026-03-28

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums als Konstanten (für TypeScript) ─────────────────────────────────────
// In SQLite werden Enums als Strings gespeichert

// LeadStatus: NEW, QUEUED_FOR_CRAWL, CRAWLED, ANALYZED, QUALIFIED, DISQUALIFIED, SITE_GENERATED, IN_REVIEW, APPROVED_FOR_OUTREACH, OUTREACH_DRAFT_READY, SENT, RESPONDED, WON, LOST
// JobStatus: PENDING, RUNNING, COMPLETED, FAILED, SKIPPED
// PageType: HOME, SERVICES, ABOUT, CONTACT, REFERENCES, IMPRINT, CAREER, OTHER
// SiteStyle: SERIOUS_CONSERVATIVE, MODERN_PREMIUM, LOCAL_APPROACHABLE, PERFORMANCE_CONVERSION
// GenerationStatus: PENDING, GENERATING, GENERATED, APPROVED, REJECTED
// OutreachType: EMAIL_SHORT, EMAIL_LONG, CONTACT_FORM, LINKEDIN, FOLLOW_UP, OBJECTION_RESPONSE
// OutreachStatus: DRAFT, APPROVED, REJECTED, SENT, BOUNCED, REPLIED
// SearchScope: NATIONWIDE, BY_STATE, BY_CITY, BY_RADIUS
// OfferTier: SMALL, MEDIUM, PREMIUM

// ─── Core: Company / Lead ──────────────────────────────────────────────────────

model Company {
  id                  String   @id @default(cuid())
  name                String
  domain              String   @unique
  websiteUrl          String?
  industry            String?
  city                String?
  state               String?  // Bundesland
  country             String   @default("DE")
  postalCode          String?
  phone               String?
  email               String?
  linkedinUrl         String?

  // Pipeline (LeadStatus als String)
  status              String   @default("NEW")
  priority            Int      @default(0)       // 0–100
  buyingProbability   Float?                       // 0–1
  opportunityScore    Float?                       // kombinierter Score

  // Discovery
  searchSource        String?  // manual | csv | google | bing | directory
  searchConfigId      String?
  searchQuery         String?
  searchRegion        String?

  // Qualifikation
  isQualified         Boolean?
  qualificationReason String?
  disqualifiedReason  String?

  // Safety
  isBlacklisted       Boolean  @default(false)
  isContacted         Boolean  @default(false)
  isDuplicate         Boolean  @default(false)
  duplicateOfId       String?

  // CRM
  notes               String?
  nextActionAt        DateTime?
  nextActionNote      String?
  ownerId             String?  // User-ID (Auth)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  contacts            Contact[]
  crawls              Crawl[]
  analyses            Analysis[]
  generatedSites      GeneratedSite[]
  outreachDrafts      OutreachDraft[]
  pipelineStates      PipelineState[]
  auditLogs           AuditLog[]
  followUpTasks       FollowUpTask[]
  competitorSnapshots CompetitorSnapshot[]
  artifacts           Artifact[]
  conversations       Conversation[]
  searchConfig        SearchConfiguration? @relation(fields: [searchConfigId], references: [id])

  @@index([status])
  @@index([industry])
  @@index([state])
  @@index([priority])
  @@index([createdAt])
}

model Contact {
  id          String   @id @default(cuid())
  companyId   String
  name        String?
  email       String?
  phone       String?
  role        String?  // z. B. "Geschäftsführer", "Marketing"
  source      String?  // imprint | website | linkedin | manual
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── Crawling ─────────────────────────────────────────────────────────────────

model Crawl {
  id              String    @id @default(cuid())
  companyId       String
  status          String    @default("PENDING")  // JobStatus
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  retryCount      Int       @default(0)

  // Basis-Metadaten
  httpStatus      Int?
  redirectUrl     String?
  finalUrl        String?
  loadTimeMs      Int?
  pageCount       Int       @default(0)

  // Artefakte
  screenshotUrl   String?
  htmlSnapshotUrl String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pages           Page[]

  @@index([companyId])
  @@index([status])
}

model Page {
  id              String   @id @default(cuid())
  crawlId         String
  url             String
  pageType        String   @default("OTHER")  // PageType

  // Inhalt
  title           String?
  metaDescription String?
  metaKeywords    String?
  h1              String?
  headings        String?  // JSON als String: Array von { level: 1|2|3, text: string }
  bodyText        String?
  html            String?

  // Artefakte
  screenshotUrl   String?

  // Erkannte Elemente
  hasViewportMeta Boolean  @default(false)
  hasCanonical    Boolean  @default(false)
  hasContactInfo  Boolean  @default(false)
  hasCTA          Boolean  @default(false)
  hasForm         Boolean  @default(false)
  hasPhone        Boolean  @default(false)
  hasAddress      Boolean  @default(false)
  hasImages       Boolean  @default(false)
  imageCount      Int      @default(0)
  ctaTexts        String?  // JSON als String: Array von gefundenen CTA-Texten
  contactEmails   String?  // JSON als String: Array von gefundenen E-Mails
  contactPhones   String?  // JSON als String: Array von gefundenen Telefonnummern

  // Technisch
  statusCode      Int?
  loadTimeMs      Int?
  wordCount       Int?

  createdAt       DateTime @default(now())

  crawl           Crawl    @relation(fields: [crawlId], references: [id], onDelete: Cascade)

  @@index([crawlId])
  @@index([pageType])
}

// ─── Analyse ──────────────────────────────────────────────────────────────────

model Analysis {
  id                  String   @id @default(cuid())
  companyId           String
  crawlId             String?

  // Gesamt-Score
  overallScore        Float?   // 0–100
  confidence          Float?   // 0–1

  // Teil-Scores
  designScore         Float?
  clarityScore        Float?
  conversionScore     Float?
  trustScore          Float?
  uxScore             Float?
  mobileScore         Float?
  seoScore            Float?
  performanceScore    Float?
  modernityScore      Float?

  // Score-Begründungen
  scoreReasons        String?  // JSON als String

  // Narrative Ergebnisse
  executiveSummary    String?
  strengths           String?  // JSON als String: Array von Strings
  weaknesses          String?  // JSON als String: Array von Strings
  quickWins           String?  // JSON als String: Array von Strings
  opportunities       String?  // JSON als String: { title, description, impact }[]
  findings            String?  // JSON als String: { category, severity, description }[]

  // Qualifikation
  isQualified         Boolean?
  qualificationReason String?
  opportunityScore    Float?   // 0–100
  buyingProbability   Float?   // 0–1

  // Technisch
  heuristicVersion    String?
  llmModel            String?
  llmPromptVersion    String?
  status              String   @default("PENDING")  // JobStatus
  errorMessage        String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([overallScore])
}

model CompetitorSnapshot {
  id            String   @id @default(cuid())
  companyId     String
  url           String
  domain        String?
  screenshotUrl String?
  overallScore  Float?
  scores        String?  // JSON als String: { [dimension]: score }
  summary       String?
  strengths     String?  // JSON als String
  weaknesses    String?  // JSON als String

  createdAt     DateTime @default(now())

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── Demo-Website-Generator ───────────────────────────────────────────────────

model GeneratedSite {
  id              String   @id @default(cuid())
  companyId       String
  version         Int      @default(1)
  variant         String   @default("A")  // A, B, C für A/B-Tests
  style           String   @default("MODERN_PREMIUM")  // SiteStyle
  status          String   @default("PENDING")  // GenerationStatus

  // Zusammenfassung für UI
  summary         String?  // Kurze Beschreibung der Demo
  headline        String?  // Hauptüberschrift der generierten Seite
  keyBenefits     String?  // JSON: Array von 3-5 Key Benefits

  // Generierter Inhalt
  htmlContent     String?
  cssContent      String?
  sections        String?  // JSON als String: Array von Sektionsdaten

  // Platzhalter & Qualität
  hasPlaceholders     Boolean  @default(false)
  placeholderCount    Int      @default(0)
  placeholderNotes    String?
  unverifiedClaims    String?  // JSON als String

  // Fehlerbehandlung
  errorCode       String?  // z. B. "LLM_TIMEOUT", "INVALID_RESPONSE"
  errorDetails    String?  // Technische Details
  retryCount      Int      @default(0)
  
  // Regeneration
  isRegeneration  Boolean  @default(false)
  previousVersionId String?  // Verweis auf vorherige Version
  regenerationReason String? // Warum neu generiert?

  // Versionierung
  generatedBy     String?  // LLM Model
  promptVersion   String?
  generationTimeMs Int?     // Dauer der Generierung

  // Review
  reviewedAt      DateTime?
  reviewedBy      String?  // User-ID
  reviewNotes     String?
  reviewRating    Int?     // 1-5 Sterne

  // Artefakte
  previewUrl      String?  // lokaler oder S3-Pfad
  screenshotUrl   String?
  thumbnailUrl    String?  // Kleine Vorschau

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version, variant])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

// ─── Outreach ─────────────────────────────────────────────────────────────────

model OutreachDraft {
  id              String   @id @default(cuid())
  companyId       String
  contactId       String?
  type            String   @default("EMAIL_SHORT")  // OutreachType
  version         Int      @default(1)

  // Empfänger (editierbar, getrennt von Kontakt)
  recipientName   String?
  recipientEmail  String?
  recipientRole   String?

  // Inhalt (editierbar)
  subject         String?
  body            String?
  
  // Angebot / Preisrahmen
  offerTier       String?  // SMALL | MEDIUM | PREMIUM
  offerPriceRange String?  // z. B. "2.500 - 5.000 €"
  offerValidUntil DateTime?

  // Referenzen auf Demo / Angebot
  generatedSiteId String?
  offerId         String?

  // Guardrails
  redFlags        String?  // JSON als String: Array von { type, description, severity }
  hasUnreviewedPlaceholders Boolean @default(false)
  isBlockedForSend Boolean @default(false)
  blockReason     String?

  // Status & Freigabe-Historie
  status          String   @default("DRAFT")  // OutreachStatus
  
  // Freigabe
  approvedAt      DateTime?
  approvedBy      String?  // User-ID
  approvalNotes   String?
  
  // Ablehnung
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  
  // Versand
  sentAt          DateTime?
  sentBy          String?  // User-ID
  openedAt        DateTime?
  repliedAt       DateTime?

  // Edit-Tracking
  lastEditedAt    DateTime?
  lastEditedBy    String?
  editCount       Int      @default(0)
  
  // Historie (letzte 10 Änderungen als JSON)
  editHistory     String?  // JSON: Array von { at, by, field, oldVal, newVal }

  // Meta
  llmModel        String?
  promptVersion   String?
  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Relations für Conversation / Follow-up Management
  initialConversation Conversation? @relation("InitialOutreach")
  followUp            FollowUp?     @relation

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

// ─── CRM / Pipeline ───────────────────────────────────────────────────────────

model PipelineState {
  id          String   @id @default(cuid())
  companyId   String
  fromStatus  String?  // LeadStatus
  toStatus    String   // LeadStatus
  changedBy   String?  // User-ID
  reason      String?

  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
}

model FollowUpTask {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  dueAt       DateTime?
  completedAt DateTime?
  type        String?   // call | email | demo | other
  notes       String?
  createdBy   String?   // User-ID
  assignedTo  String?   // User-ID

  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([dueAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  
  // Event-Kategorisierung für Filterung
  eventType   String   // SYSTEM | WORKFLOW | QUALIFICATION | DEMO | OUTREACH | SEND | ERROR
  action      String   // z. B. "outreach.approved", "site.generated", "lead.status_changed"
  
  // Betroffene Entity
  entityType  String?  // Company, Crawl, Analysis, GeneratedSite, OutreachDraft
  entityId    String?
  
  // Auslöser
  userId      String?  // Bei manuellen Aktionen
  isSystem    Boolean  @default(false)  // true bei automatischen Prozessen
  
  // Inhalt
  title       String?  // Kurze Überschrift für die Timeline
  description String?  // Details
  metadata    String?  // JSON als String für technische Details
  
  // Für Fehler-Events
  severity    String?  // INFO | WARNING | ERROR | CRITICAL
  errorCode   String?
  
  createdAt   DateTime @default(now())

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([eventType])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// ─── Artefakte / Assets ───────────────────────────────────────────────────────

model Artifact {
  id          String   @id @default(cuid())
  companyId   String
  type        String   // screenshot | html_snapshot | pdf | micro_audit | offer_page
  url         String
  filename    String?
  mimeType    String?
  sizeBytes   Int?
  metadata    String?  // JSON als String

  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([type])
}

// ─── Konfiguration ────────────────────────────────────────────────────────────

model SearchConfiguration {
  id          String   @id @default(cuid())
  name        String
  isActive    Boolean  @default(false)
  description String?

  // Geografisches Suchgebiet
  scope       String   @default("NATIONWIDE")  // SearchScope
  country     String   @default("DE")
  states      String?  // JSON als String: Bundesländer
  cities      String?  // JSON als String
  postalCodes String?  // JSON als String
  radiusKm    Int?
  centerCity  String?
  centerLat   Float?
  centerLng   Float?

  // Branchenfilter
  industries  String?  // JSON als String

  // Ausschlüsse
  excludeLargeCorps   Boolean @default(true)
  excludeGovt         Boolean @default(true)
  minEmployees        Int?
  maxEmployees        Int?    @default(500)
  excludeKeywords     String? // JSON als String

  // Limits
  maxLeadsPerRun  Int? @default(50)
  dailyLimit      Int? @default(100)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies   Company[]

  @@index([isActive])
}

model IndustryTemplate {
  id                String   @id @default(cuid())
  industry          String   @unique
  displayName       String
  description       String?
  isActive          Boolean  @default(true)

  // Template-Daten
  keySections       String?  // JSON als String
  commonWeaknesses  String?  // JSON als String
  strongCtaTypes    String?  // JSON als String
  headlinePatterns  String?  // JSON als String
  trustElements     String?  // JSON als String
  styleDirection    String?  // z. B. "seriös, klar, vertrauenswürdig"
  offerLogic        String?  // JSON als String
  seoKeywords       String?  // JSON als String

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OfferTemplate {
  id            String   @id @default(cuid())
  name          String
  tier          String   // OfferTier
  description   String?
  tagline       String?

  // Inhalt
  scope         String?
  benefits      String?  // JSON als String
  features      String?  // JSON als String
  deliverables  String?  // JSON als String

  // Preis
  priceMin      Int?     // EUR
  priceMax      Int?     // EUR
  durationDays  Int?     // geschätzte Umsetzungszeit

  // Targeting
  suitableIndustries String? // JSON als String
  suitableForScore   String? // JSON als String

  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OutreachTemplate {
  id              String   @id @default(cuid())
  name            String
  type            String   // OutreachType
  industry        String?  // null = universell
  description     String?

  subjectTemplate String?
  bodyTemplate    String?
  // Platzhalter: {{company_name}}, {{city}}, {{weakness_1}}, {{demo_url}}, {{offer_name}}

  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Job-System ───────────────────────────────────────────────────────────────

model JobRecord {
  id             String   @id @default(cuid())
  type           String   // crawl | analyze | generate_site | generate_outreach | send_outreach | ...
  status         String   @default("PENDING")  // JobStatus
  entityType     String?  // Company | OutreachDraft | ...
  entityId       String?

  startedAt      DateTime?
  completedAt    DateTime?
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3)
  errorMessage   String?
  stackTrace     String?

  payload        String?  // JSON als String
  result         String?  // JSON als String
  progress       Int       @default(0)  // 0–100

  idempotencyKey String?   @unique
  queueJobId     String?   // BullMQ Job ID

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type, status])
  @@index([entityId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Conversation / Follow-up / Reply Management (MVP)
// ═══════════════════════════════════════════════════════════════════════════════
//
// Enums (werden als Strings gespeichert):
// ReplySentiment: POSITIVE | NEUTRAL | NEGATIVE | SPAM
// ConversationStatus: PENDING | REPLIED | FOLLOW_UP_SENT | CLOSED_WON | CLOSED_LOST | NO_REPLY_CLOSED
// FollowUpStatus: DRAFT | SENT | CANCELLED

// Conversation: Container für initialen Outreach, Replies und Follow-ups
// Im MVP: maximal eine aktive Conversation pro Lead
model Conversation {
  id                String              @id @default(cuid())
  companyId         String              
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Initiale Outreach-Verknüpfung (optional, da Conversation auch manuell erstellt werden könnte)
  initialOutreachId String?             @unique
  initialOutreach   OutreachDraft?      @relation("InitialOutreach", fields: [initialOutreachId], references: [id])
  
  // Status
  status            String              @default("PENDING")  // ConversationStatus
  currentSentiment  String?
  
  // Zeit-Tracking
  firstSentAt       DateTime
  lastContactAt     DateTime
  replyReceivedAt   DateTime?
  
  // Follow-up Logik
  followUpCount     Int                 @default(0)
  nextFollowUpDueAt DateTime?
  
  // Verknüpfungen
  replies           Reply[]
  followUps         FollowUp[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Index für Queries und Prüfung auf aktive Conversations
  @@index([companyId, status])
  @@index([status])
  @@index([nextFollowUpDueAt])
}

// Reply: Eingehende Antwort auf eine Conversation
model Reply {
  id              String          @id @default(cuid())
  conversationId  String
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  sentiment       String  // ReplySentiment
  content         String?         // Optional: Antworttext
  notes           String?         // Interne Notizen
  
  receivedAt      DateTime        @default(now())
  createdBy       String          // Wer hat die Antwort erfasst
  
  createdAt       DateTime        @default(now())
  
  @@index([conversationId])
  @@index([sentiment])
}

// FollowUp: Ausgehendes Follow-up zu einer Conversation
model FollowUp {
  id              String          @id @default(cuid())
  conversationId  String
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  sequenceNumber  Int             // 1, 2, 3
  status          String          @default("DRAFT")  // FollowUpStatus
  outreachDraftId String?         @unique
  outreachDraft   OutreachDraft?  @relation(fields: [outreachDraftId], references: [id])
  
  sentAt          DateTime?
  dueAt           DateTime        // Wann war das Follow-up fällig
  
  createdAt       DateTime        @default(now())
  
  @@index([conversationId])
  @@index([status])
}
