# ─── Datenbank ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/website_rescue_agent"

# ─── Redis (für BullMQ) ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generieren mit: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optionale OAuth Provider (z. B. GitHub für internes Login)
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Primärer Provider: openai | anthropic | ollama
LLM_PROVIDER="openai"

OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# Modelle (Defaults können überschrieben werden)
LLM_MODEL_ANALYSIS="gpt-4o"
LLM_MODEL_GENERATION="gpt-4o"
LLM_MODEL_OUTREACH="gpt-4o-mini"

# ─── Storage ────────────────────────────────────────────────────────────────────
# Lokal (default) oder S3-kompatibel
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./storage"

# S3 (optional)
# STORAGE_S3_BUCKET=""
# STORAGE_S3_REGION="eu-central-1"
# STORAGE_S3_ACCESS_KEY=""
# STORAGE_S3_SECRET_KEY=""
# STORAGE_S3_ENDPOINT=""  # für MinIO / Hetzner etc.

# ─── E-Mail / Outreach ─────────────────────────────────────────────────────────
# Nur für optionalen direkten Versand (immer nach Freigabe!)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Website Rescue Agent <noreply@yourdomian.de>"

# ─── Playwright / Crawler ──────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS="true"
CRAWL_TIMEOUT_MS="30000"
CRAWL_MAX_PAGES="10"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"  # development | staging | production

# ─── Worker / Queue Configuration ─────────────────────────────────────────────
CRAWL_CONCURRENCY="3"
LLM_CONCURRENCY="2"
SEARCH_CONCURRENCY="2"
EMAIL_CONCURRENCY="1"
WORKER_CONCURRENCY="4"        # General worker concurrency
WORKER_RATE_LIMIT_MAX="10"    # Max jobs per rate limit window
WORKER_RATE_LIMIT_DURATION="1000"  # Rate limit window in ms

# Set to "true" to use in-memory mock queue instead of Redis
USE_MOCK_QUEUE="false"

# ─── Sentry Error Monitoring ───────────────────────────────────────────────────
# DSN von https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""  # Server-side DSN (optional, falls unterschiedlich)
SENTRY_ORG=""  # Organisation slug
SENTRY_PROJECT=""  # Project slug
SENTRY_AUTH_TOKEN=""  # Auth token für Source Map Upload (CI only)
SENTRY_RELEASE=""  # Wird automatisch in CI gesetzt (z.B. Git SHA)
SENTRY_DEBUG="false"  # Setze auf "true" für Debug-Logs
