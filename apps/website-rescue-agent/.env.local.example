# =============================================================================
# Website Rescue Agent - Environment Variables
# =============================================================================
# 
# Kopiere diese Datei nach .env.local und fülle die Werte aus.
# .env.local wird nicht committed (in .gitignore).
#
# Status der Integration:
# - ✅ Playwright: Funktioniert ohne ENV
# - ⚠️ Sentry: Braucht SENTRY_DSN
# - ⚠️ Worker: Braucht REDIS_URL
# - ⚠️ LLM: Braucht OPENAI_API_KEY oder ANTHROPIC_API_KEY
#
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (default für local dev)
DATABASE_URL="file:./dev.db"

# PostgreSQL (für Production)
# DATABASE_URL="postgresql://user:password@localhost:5432/website_rescue_agent"

# =============================================================================
# AUTH (NextAuth)
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars-long"

# =============================================================================
# LLM PROVIDERS (Optional - für KI-Analyse)
# =============================================================================
# Ohne diese Keys läuft die App im "heuristischen Modus"
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# =============================================================================
# SENTRY (Error Tracking) - Braucht DSN für Aktivierung
# =============================================================================
# SENTRY_DSN="https://xxx@yyy.ingest.de.sentry.io/zzz"
# SENTRY_ORG="lucello-studio"
# SENTRY_PROJECT="website-rescue-agent"
# SENTRY_RELEASE="1.0.0"

# =============================================================================
# REDIS (BullMQ Worker) - Braucht Redis für Aktivierung
# =============================================================================
# Lokal: redis://localhost:6379
# Docker: docker run -d -p 6379:6379 redis:alpine
# Cloud: redis://username:password@host:port
#
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# EMAIL (Für Outreach-Versand) - Optional
# =============================================================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@yourdomain.com"

# =============================================================================
# WORKER CONCURRENCY (Optional)
# =============================================================================
# CRAWL_CONCURRENCY="3"
# LLM_CONCURRENCY="2"
# EMAIL_CONCURRENCY="1"
